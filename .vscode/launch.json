{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug current TS file",
      "runtimeExecutable": "${workspaceFolder}/node_modules/tsx/dist/cli.mjs",
      "args": ["${file}"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug hello.ts",
      "runtimeExecutable": "${workspaceFolder}/node_modules/tsx/dist/cli.mjs",
      "args": ["${workspaceFolder}/src/phase-0/hello.ts"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
