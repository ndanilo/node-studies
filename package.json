{
  "name": "nodejs-study",
  "version": "1.0.0",
  "description": "Node.js & TypeScript learning lab for C# developers — Applied AI focus",
  "type": "module",
  "scripts": {
    "hello": "tsx src/phase-0/hello.ts",
    "env-demo": "tsx src/phase-0/env-demo.ts",
    "phase1": "tsx src/phase-1/fundamentals.ts",
    "word-counter": "tsx src/phase-1/word-counter.ts",
    "phase2": "tsx src/phase-2/fundamentals.ts",
    "phase2-exercise": "tsx src/phase-2/exercise.ts",
    "phase3": "tsx src/phase-3/fundamentals.ts",
    "phase3-exercise": "tsx src/phase-3/exercise.ts",
    "phase4": "tsx src/phase-4/fundamentals.ts",
    "phase4-exercise": "tsx src/phase-4/exercise.ts",
    "phase5": "tsx src/phase-5/fundamentals.ts",
    "phase5-exercise": "tsx src/phase-5/exercise.ts",
    "phase6-exercise": "tsx src/phase-6/exercise.ts",
    "phase7": "tsx src/phase-7/fundamentals.ts",
    "phase7-exercise": "tsx src/phase-7/exercise.ts",
    "phase8": "tsx src/phase-8/fundamentals.ts",
    "phase8-server": "tsx src/phase-8/exercise.ts",
    "phase9": "tsx src/phase-9/fundamentals.ts",
    "phase9-agent": "tsx src/phase-9/exercise.ts",
    "phase9-server": "tsx src/phase-9/server.ts",
    "phase9-evals": "tsx src/phase-9/evals/run-evals.ts",
    "phase10": "tsx src/phase-10/fundamentals.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/phase-10",
    "lint:all": "eslint src",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "dev": "tsx watch src/phase-0/hello.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "nodejs",
    "typescript",
    "learning",
    "applied-ai"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "express": "^5.2.1",
    "openai": "^6.42.0",
    "pino": "^10.3.1",
    "zod": "^3.24.0"
  }
}
